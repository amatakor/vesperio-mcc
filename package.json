{
  "name": "vesperio-mcc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "check:feed": "bun scripts/check-feed.ts",
    "check:registry": "bun scripts/check-registry.ts",
    "check:signals": "bun scripts/check-signals.ts",
    "check:orbits": "bun scripts/check-orbits.ts",
    "test": "bun test scripts",
    "build": "bun run typecheck && bun run check:feed && bun run check:registry && bun run check:signals && bun run check:orbits && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && bun scripts/prerender.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "dseg": "^0.46.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "satellite.js": "^6.0.2",
    "three": "^0.185.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.185.0",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
